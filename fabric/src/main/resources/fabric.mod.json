{
  "schemaVersion": 1,
  "id": "terrasect",
  "version": "${version}",
  "name": "Terrasect",
  "description": "Multi-loader mod foundation for Terrasect",
  "authors": ["Terrasect Team"],
  "contact": {
    "sources": "https://example.com/terrasect"
  },
  "license": "MIT",
  "environment": "*",
  "entrypoints": {
    "main": [
      "com.terrasect.fabric.TerrasectFabric"
    ],
    "fabric-gametest": [
      "com.terrasect.fabric.GameTestIntegration"
    ],
    "fabric-client-gametest": [
      "com.terrasect.fabric.client.ClientGameTestIntegration"
    ]
  },
  "depends": {
    "fabricloader": ">=${fabric_loader_version}",
    "minecraft": ">=${minecraft_version}",
    "java": ">=${java_version}"
  },
  "mixins": [
    "terrasect.mixins.json"
  ]
}
