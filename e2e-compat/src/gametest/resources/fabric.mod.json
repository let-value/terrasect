{
  "schemaVersion": 1,
  "id": "${gametest_mod_id}",
  "version": "${version}",
  "name": "${mod_name} E2E Compat Tests",
  "description": "Third-party mod compatibility client game tests for ${mod_name}.",
  "authors": [
    "${mod_authors}"
  ],
  "license": "${mod_license}",
  "environment": "client",
  "entrypoints": {
    "client": [
      {
        "value": "terrasect.CompatGameTestExit",
        "adapter": "kotlin"
      }
    ],
    "fabric-client-gametest": [
      {
        "value": "terrasect.CompatSmokeGameTest",
        "adapter": "kotlin"
      }
    ]
  },
  "depends": {
    "fabricloader": ">=${fabric_loader_version}",
    "minecraft": "~${minecraft_version}",
    "java": ">=${java_version}",
    "fabric-api": ">=${fabric_api_version}",
    "fabric-language-kotlin": ">=${fabric_kotlin_version}",
    "terrasect": "*"
  }
}
