{
  "schemaVersion": 1,
  "id": "${gametest_mod_id}",
  "version": "${version}",
  "name": "${mod_name} E2E Tests",
  "description": "Client game tests for ${mod_name}.",
  "authors": [
    "${mod_authors}"
  ],
  "license": "${mod_license}",
  "environment": "client",
  "entrypoints": {
    "fabric-client-gametest": [
      {
        "value": "terrasect.SmokeGameTest",
        "adapter": "kotlin"
      },
      {
        "value": "terrasect.TerrasectFabricClientGameTest",
        "adapter": "kotlin"
      },
      {
        "value": "terrasect.VanillaWorldDigestTest",
        "adapter": "kotlin"
      },
      {
        "value": "terrasect.TerrasectWorldDigestTest",
        "adapter": "kotlin"
      },
      {
        "value": "terrasect.MobConstraintBlockByNameGameTest",
        "adapter": "kotlin"
      },
      {
        "value": "terrasect.StructureConstraintVanillaGameTest",
        "adapter": "kotlin"
      },
      {
        "value": "terrasect.StructureConstraintHighDensityGameTest",
        "adapter": "kotlin"
      },
      {
        "value": "terrasect.StructureConstraintLocateGameTest",
        "adapter": "kotlin"
      },
      {
        "value": "terrasect.StructureConstraintBanByModGameTest",
        "adapter": "kotlin"
      },
      {
        "value": "terrasect.StructureConstraintAllowByModGameTest",
        "adapter": "kotlin"
      },
      {
        "value": "terrasect.StructureConstraintBanByTagGameTest",
        "adapter": "kotlin"
      },
      {
        "value": "terrasect.StructureConstraintAllowByTagGameTest",
        "adapter": "kotlin"
      },
      {
        "value": "terrasect.StructureConstraintBanByNameGameTest",
        "adapter": "kotlin"
      },
      {
        "value": "terrasect.StructureConstraintAllowByNameGameTest",
        "adapter": "kotlin"
      },
      {
        "value": "terrasect.StructureConstraintLocateRuinedPortalGameTest",
        "adapter": "kotlin"
      },
      {
        "value": "terrasect.StructureConstraintStatisticsTest",
        "adapter": "kotlin"
      },
      {
        "value": "terrasect.LootConstraintBlockAllGameTest",
        "adapter": "kotlin"
      }
    ]
  },
  "depends": {
    "fabricloader": ">=${fabric_loader_version}",
    "minecraft": "~${minecraft_version}",
    "java": ">=${java_version}",
    "fabric-api": ">=${fabric_api_version}",
    "fabric-language-kotlin": ">=${fabric_kotlin_version}",
    "terrasect": "*"
  }
}
